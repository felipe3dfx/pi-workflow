{
  "name": "@felipe.3dfx/pi-workflow",
  "version": "0.1.1",
  "type": "module",
  "description": "Pi workflow meta-configuration package for explicit companion package setup.",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi",
    "workflow",
    "skills",
    "extensions"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/felipe3dfx/pi-workflow.git"
  },
  "bugs": {
    "url": "https://github.com/felipe3dfx/pi-workflow/issues"
  },
  "homepage": "https://github.com/felipe3dfx/pi-workflow#readme",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "pi-workflow-sync": "./scripts/pi-workflow-sync.mjs"
  },
  "files": [
    "README.md",
    "scripts/**/*.mjs",
    "package.json",
    "LICENSE",
    "extensions/",
    "assets/",
    "skills/",
    "prompts/"
  ],
  "scripts": {
    "pack:dry-run": "npm pack --dry-run",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check:biome": "biome check --formatter-enabled=false .",
    "check:focused-tests": "node scripts/forbid-focused-tests.mjs",
    "generate:public-workflows": "node scripts/generate-public-workflows.mjs --write",
    "check:generated": "node scripts/generate-public-workflows.mjs --check",
    "check:agent-assets": "node scripts/check-agent-assets.mjs --check",
    "check:publish": "node scripts/validate-pi-package.mjs",
    "check:release": "node scripts/validate-release.mjs",
    "check:distribution": "node scripts/validate-packed-distribution.mjs",
    "check:acceptance": "node scripts/check-acceptance.mjs",
    "check:typecheck": "tsc --noEmit",
    "check:knip": "knip",
    "check:coverage": "node --test --experimental-test-coverage --test-coverage-include='extensions/runtime-linear-delivery-ticket.ts' --test-coverage-lines=97 --test-coverage-branches=80 --test-coverage-functions=95 test/linear-delivery-ticket.test.mjs",
    "check": "npm run check:biome && npm run check:typecheck && npm run check:knip && npm run check:focused-tests && npm run check:generated && npm run check:agent-assets && npm run check:publish && npm run check:release && npm run check:coverage && node --test test/*.test.mjs && npm run check:distribution && npm run check:acceptance",
    "prepublishOnly": "npm run check"
  },
  "pi": {
    "extensions": [
      "./extensions/pi-workflow.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "engines": {
    "node": ">=22.19"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@types/node": "^22.20.1",
    "knip": "^6.25.0",
    "typescript": "^7.0.2",
    "yaml": "2.9.0"
  }
}
