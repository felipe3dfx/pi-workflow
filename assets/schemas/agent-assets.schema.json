{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/felipe3dfx/pi-workflow/schemas/agent-assets.schema.json",
  "title": "pi-workflow agent asset catalog",
  "type": "object",
  "required": ["schemaVersion", "assets"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "name", "version", "source", "digest"],
        "properties": {
          "kind": { "const": "agent" },
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "integer", "minimum": 1 },
          "source": {
            "type": "string",
            "pattern": "^assets/agents/[^/]+\\.md$"
          },
          "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
